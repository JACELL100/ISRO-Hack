# ─── ISRO Lunar Ice Explorer — Backend Environment Variables ─────────────────
# Copy this file to .env and fill in values for local development.
# On Render, set these in the dashboard (Environment > Add Environment Variable)
# or they are already declared in render.yaml.

# Python output encoding (avoids Unicode errors on Windows)
PYTHONIOENCODING=utf-8
PYTHONUNBUFFERED=1

# Analysis grid size in pixels (256 recommended; use 128 for faster cold starts)
ISRO_SCENE_SIZE=256

# CORS allowed origins — comma-separated list, or * for all origins.
# After deploying to Vercel, set this to your Vercel URL to lock it down.
# Example: CORS_ORIGINS=https://isro-lunar-ice.vercel.app
CORS_ORIGINS=*

# Optional: path to real Chandrayaan-2 DFSAR/OHRC product directory.
# When set and valid, the real-data loader activates automatically.
# Leave unset to use the LOLA-DEM + calibrated synthetic DFSAR pipeline.
# ISRO_DATA_DIR=/path/to/dfsar_products
