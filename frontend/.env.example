# ─── ISRO Lunar Ice Explorer — Frontend Environment Variables ────────────────
# Copy this file to .env.local for local development.
# On Vercel, set NEXT_PUBLIC_API_URL in:
#   Project Settings → Environment Variables

# URL of the FastAPI backend.
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (replace with your actual Render service URL):
# NEXT_PUBLIC_API_URL=https://isro-lunar-ice-backend.onrender.com
